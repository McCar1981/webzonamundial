# Sanity.io Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_TOKEN=""

# SMTP (waitlist + notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS=""
SMTP_FROM="noreply@zonamundial.app"

# Noticias ingest pipeline (Fase 2)
# GNews — https://gnews.io/dashboard (free tier: 100 req/day)
GNEWS_API_KEY=""

# Cron protection — generate with `openssl rand -hex 32`
# On Vercel, set the same value in Settings → Environment Variables → CRON_SECRET
CRON_SECRET=""

# Anthropic Claude API — used by the article rewriter
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ── Supabase Auth ────────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard
# Auth > URL Configuration:
#   Site URL: https://zonamundial.app
#   Redirect URLs: https://zonamundial.app/auth/callback
# Auth > Providers: enable Email (magic link), Google, Apple.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Site URL (callbacks OAuth + emails)
NEXT_PUBLIC_SITE_URL="https://zonamundial.app"

# ── Vercel KV (Upstash) ──────────────────────────────────────────────────
# Lo inyecta automáticamente "Connect Project" en Vercel.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ── Admin export ─────────────────────────────────────────────────────────
# Token largo y aleatorio. Genera con: openssl rand -hex 32
ADMIN_TOKEN=""

# ── Stripe (Founders Pass) ───────────────────────────────────────────────
# Obtener desde https://dashboard.stripe.com/apikeys (modo TEST mientras
# se prueba; en producción usar las claves live).
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret de https://dashboard.stripe.com/webhooks tras
# crear el endpoint /api/webhooks/stripe (rellenar después del primer deploy).
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price ID del producto "Founders Pass" creado en Stripe Dashboard.
STRIPE_FOUNDERS_PASS_PRICE_ID="price_..."
