# ═══════════════════════════════════════════════════════════════════════════════
# ZonaMundial — Variables de entorno
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env.local y rellena los valores.
# Las marcadas con [REQ] son obligatorias para el funcionamiento básico.
# Las marcadas con [OPT] son opcionales (features desactivadas si faltan).
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core / Next.js ────────────────────────────────────────────────────────────
NODE_ENV="development"
# [REQ] URL pública del sitio (usada en callbacks OAuth, emails, OG images)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard
# [REQ] URL y anon key de Supabase (cliente navegador + server)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# [REQ] Service role key — MÁXIMO PRIVILEGIO. NUNCA expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=""

# ── Vercel KV (Upstash) ───────────────────────────────────────────────────────
# Lo inyecta automáticamente "Connect Project" en Vercel.
# [REQ] Cache KV para datos en vivo, trivia, leaderboards
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ── Stripe (Founders Pass + Pagos) ────────────────────────────────────────────
# Obtener desde https://dashboard.stripe.com/apikeys
# [REQ] Secret key de Stripe (server-side only)
STRIPE_SECRET_KEY="sk_test_..."
# [REQ] Webhook signing secret de https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Admin / Seguridad ─────────────────────────────────────────────────────────
# [REQ] Token largo y aleatorio para acceso a /admin/*
# Genera con: openssl rand -hex 32
ADMIN_TOKEN=""
# [REQ] Contraseña del panel admin (fallback si no hay token)
ADMIN_PASSWORD=""
# [REQ] Secret para proteger crons — generate con `openssl rand -hex 32`
CRON_SECRET=""

# ── Web Push (Notificaciones push) ────────────────────────────────────────────
# [OPT] Claves VAPID para Web Push. Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:push@zonamundial.app"

# ── Anthropic / IA ────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
# [REQ] API key de Anthropic (coach, trivia, noticias, micro)
ANTHROPIC_API_KEY=""
# [OPT] Modelos específicos por módulo (fallback al modelo por defecto)
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
ANTHROPIC_MODEL_TRIVIA="claude-haiku-4-5-20251001"
ANTHROPIC_MODEL_NARRATIVE="claude-haiku-4-5-20251001"
ANTHROPIC_MODEL_NARRATOR="claude-haiku-4-5-20251001"
ANTHROPIC_MODEL_MICRO="claude-haiku-4-5-20251001"
# [OPT] Activar IA para generar micro-predicciones (true/false)
MICRO_AI="false"

# ── Blog / Evergreen (generación IA) ──────────────────────────────────────────
# [OPT] Modelo para generar posts del blog
BLOG_GENERATOR_MODEL="claude-haiku-4-5-20251001"
# [OPT] Timeout para generación de imágenes del blog (ms)
BLOG_IMG_TIMEOUT_MS="30000"

# ── Noticias / Pipeline de ingest ─────────────────────────────────────────────
# [OPT] Activar enriquecimiento de noticias con IA (true/false)
NEWS_ENRICH="false"
# [OPT] Cap diario de noticias a procesar
NEWS_DAILY_CAP="10"
# [OPT] Umbrales mínimos del crítico de calidad
NEWS_CRITIC_MIN_CRITICA="60"
NEWS_CRITIC_MIN_MEDIA="40"
# [OPT] Backfill: beats por ventana y días de ventana
NEWS_BACKFILL_BEATS_PER_WINDOW="5"
NEWS_BACKFILL_WINDOW_DAYS="7"
# [OPT] Rate limiting del pipeline
NEWS_COLD_PER_TICK="3"
NEWS_QUERIES_PER_TICK="5"
NEWS_REWRITE_LIMIT="20"
# [OPT] Enriquecimiento de artículos
NEWS_ENRICH_CONCURRENCY="3"
NEWS_ENRICH_MAX_CHARS="8000"
NEWS_ENRICH_MIN_CHARS="500"
NEWS_ENRICH_TIMEOUT_MS="30000"
# [OPT] API key de GNews (https://gnews.io/dashboard)
GNEWS_API_KEY=""

# ── API Sports / Datos en vivo ────────────────────────────────────────────────
# [OPT] API key de API-Football (vía API-Sports)
# https://dashboard.api-football.com/
API_SPORTS_KEY=""
# [OPT] API key de RapidAPI (fallback)
RAPIDAPI_KEY=""
# [OPT] Mapeo de fixtures de API-Football
MC_FIXTURE_MAP=""
# [OPT] IDs de liga y temporada del Mundial
WC_LEAGUE_ID=""
WC_SEASON=""

# ── OAuth Providers ───────────────────────────────────────────────────────────
# [OPT] Apple Sign In
APPLE_CLIENT_ID=""
# [OPT] Twitch (creadores)
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# [REQ] Servidor SMTP para emails transaccionales
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS=""
SMTP_FROM="noreply@zonamundial.app"
# [OPT] Email de soporte mostrado en la app
SUPPORT_EMAIL="hola@zonamundial.app"
# [OPT] Email para reportes de crons
CRON_REPORT_EMAIL=""
# [OPT] Secret para enlaces de baja de email
EMAIL_UNSUB_SECRET=""

# ── Centro de Control / Monitorización (Ops) ──────────────────────────────────
# [OPT] Alertas Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# [OPT] User IDs de Supabase que reciben push de ops
OPS_PUSH_USER_IDS=""
# [OPT] Email para alertas de ops (fallback)
OPS_ALERT_EMAIL=""

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# [OPT] Configuración de Sanity Studio
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_TOKEN=""

# ── Ads / Marketing ───────────────────────────────────────────────────────────
# [OPT] Google AdSense ID
NEXT_PUBLIC_ADSENSE_ID=""
# [OPT] Disponibilidad de la app: "live" | "waitlist" | "coming"
NEXT_PUBLIC_APP_AVAILABILITY="waitlist"

# ── Vercel (inyectadas automáticamente en deploy) ─────────────────────────────
# No necesitas configurarlas manualmente en local.
VERCEL_REGION=""
VERCEL_URL=""
