    "trivia": [
      {
        "text": "Como ZAIRE (1971-1997) jugó el Mundial 1974 (Alemania Federal). Tras la caída de Mobutu en 1997, el país recuperó el nombre histórico de República Democrática del Congo (RDC). El Mundial 2026 será su 1ª participación bajo el nombre actual y la 2ª histórica.",
        "source": "FECOFA + Wikipedia",
        "verified_at": "2026-04-29",
        "status": "validated"
      }
    ]
  },
  "wc_2026": {
    "qualified_via": "playoff_intercontinental",
    "qualifying_summary": "RD Congo clasificó por la VÍA MÁS LARGA: 2ª del Grupo B CAF (detrás de Senegal con 22 pts) → semifinal play-off africano: 1-0 Camerún (Mbemba 90+1') en Rabat → final play-off africano: 1-1 Nigeria (4-3 penales) → repechaje intercontinental FIFA en marzo 2026 en México → final intercontinental: 1-0 Jamaica (Tuanzebe min 100, Estadio Guadalajara). Es la 2ª participación histórica del país en Mundiales: la 1ª fue como ZAIRE en 1974 (Alemania Federal). Los Leopardos disputarán el Grupo K con Portugal, Colombia y Uzbekistán. Eliminaron a 3 gigantes africanos (Camerún, Nigeria) y vivieron una odisea histórica.",
