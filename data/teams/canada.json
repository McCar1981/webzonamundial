    "coach": {
      "name": "Jesse Marsch",
      "age": 52,
      "nationality": "Estados Unidos",
      "since": "2024-05-13",
      "previous_teams": [
        "Leeds United (2022-2023, Premier League)",
        "RB Leipzig (2021-2022, Bundesliga, despedido tras 4 meses)",
